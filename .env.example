# Copy this file to ".env" and fill in your real values.
# Until eBay keys are set, the app runs in dry-run mode with sample data.

# --- eBay Browse API (developer.ebay.com -> Application Keysets -> Production) ---
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# --- Pushover (pushover.net) ---
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=
